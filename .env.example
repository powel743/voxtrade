# ─────────────────────────────────────────────────────────────
# VoxTrade — root reference of all environment variables
# Each sub-project has its own .env.example; this is an overview.
# ─────────────────────────────────────────────────────────────

# ── backend/.env ──────────────────────────────────────────────
GEMINI_API_KEY=
MT5_BRIDGE_URL=https://your-ngrok-or-cloudflare-url-here
PORT=3001
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/voxtrade
MONGODB_DB=voxtrade
CONFIDENCE_THRESHOLD=7
FRONTEND_URL=https://your-app.vercel.app

# ── mt5-bridge/.env ───────────────────────────────────────────
MT5_LOGIN=your_account_number
MT5_PASSWORD=your_password
MT5_SERVER=Exness-MT5Real
BRIDGE_PORT=5001

# ── frontend/.env ─────────────────────────────────────────────
VITE_BACKEND_URL=https://your-app.onrender.com
